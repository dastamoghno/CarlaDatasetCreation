# Traffic profile: FLOW — fast bidirectional flow.
#
# Cars stream through the corridor in BOTH directions at the posted speed under the
# feeder-aware green-wave. Best Doppler signal (vehicles move fast); lower instantaneous
# occupancy because cars flow THROUGH rather than accumulate (~4-6 in view at a time).
# Validated capture: Data/sensor_capture_20260607_211506
#   matched 7.0 pts/radar/frame (car 4.9 + truck 1.7 + ped 0.4), match rate 48%.
#
# Usage:  PROFILE=flow ./run_sim.sh --radar-count 8
# Or:     source config/profile_flow.env   (then run the pipeline manually)

export DATASET_RADAR_VERTICAL_FOV_DEG=40
export DATASET_RADAR_POINTS_PER_SECOND=15000
export DATASET_RADAR_PITCH_DEG=8

export DATASET_TRAFFIC_LIGHTS_GREEN_WAVE=1
export DATASET_TARGET_CAR_COUNT=36
export DATASET_VEHICLE_SPEED_REDUCTION_PCT=0      # full posted speed -> strong Doppler
export DATASET_SAFE_FOLLOWING_DISTANCE_M=5.0      # normal gap -> cars don't bunch up

# Grounded match margins (0.5 m -> 95% on-body); offline labeling after capture.
export DATASET_RADAR_HIT_MATCH_MAX_MARGIN_M=0.5
export DATASET_RADAR_SINGLE_CANDIDATE_MAX_MARGIN_M=1.0
export DATASET_RADAR_AUTO_MARGIN=0
export DATASET_LABEL_RADAR_AFTER_CAPTURE=1
