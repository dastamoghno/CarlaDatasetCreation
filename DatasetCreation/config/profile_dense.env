# Traffic profile: DENSE — dense, stop-and-go traffic (occlusion study).
#
# Tight following distance + reduced speed pack the corridor so vehicles crawl and
# OCCLUDE one another (e.g. a truck radar-shadows a car behind it). Higher instantaneous
# occupancy than FLOW; reduced Doppler (cars slow/stopped). Same radar + labeling config
# as FLOW, so the two profiles are directly comparable. Larger fleet feeds the queue.
#
# Usage:  PROFILE=dense ./run_sim.sh --radar-count 8
# Or:     source config/profile_dense.env   (then run the pipeline manually)

export DATASET_RADAR_VERTICAL_FOV_DEG=40
export DATASET_RADAR_POINTS_PER_SECOND=15000
export DATASET_RADAR_PITCH_DEG=8

export DATASET_TRAFFIC_LIGHTS_GREEN_WAVE=1
export DATASET_TARGET_CAR_COUNT=40                # more cars feeding the queue
export DATASET_VEHICLE_SPEED_REDUCTION_PCT=45     # crawl -> longer dwell, denser frames
export DATASET_SAFE_FOLLOWING_DISTANCE_M=2.0      # tight gap -> cars bunch up / pack

# Grounded match margins (0.5 m -> 95% on-body); offline labeling after capture.
export DATASET_RADAR_HIT_MATCH_MAX_MARGIN_M=0.5
export DATASET_RADAR_SINGLE_CANDIDATE_MAX_MARGIN_M=1.0
export DATASET_RADAR_AUTO_MARGIN=0
export DATASET_LABEL_RADAR_AFTER_CAPTURE=1
